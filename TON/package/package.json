{
  "name": "@storm-trade/sdk",
  "description": "Storm Trade protocol SDK",
  "version": "1.0.0-rc.4",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/lib/index.d.ts",
  "module": "dist/index.esm.js",
  "homepage": "https://storm.tg",
  "scripts": {
    "run:ts": "ts-node",
    "run:bt": "npx blueprint run",
    "test": "jest",
    "render-schemas": "ts-node scripts/renderSchemas",
    "ts:check": "npx tsc --noEmit",
    "build": "tsdx build -i lib/index.ts --name index --format esm,cjs --tsconfig tsconfig.lib.json",
    "prepublish": "npm run build && ts-node scripts/prepublish.ts",
    "postpublish": "ts-node scripts/postpublish.ts",
    "prepare": "husky"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "storm-trade",
    "ton"
  ],
  "publishConfig": {
    "access": "public"
  },
  "browserslist": {
    "production": [
      "chrome >= 67",
      "edge >= 79",
      "firefox >= 68",
      "opera >= 54",
      "safari >= 14"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@orbs-network/ton-access": "^2.3.3",
    "@ton/blueprint": "^0.27.0",
    "@ton/core": ">=0.59.0",
    "@ton/crypto": "^3.2.0",
    "@ton/sandbox": "^0.23.0",
    "@ton/test-utils": "^0.3.1",
    "@ton/ton": "^15.1.0",
    "@tonconnect/sdk": "^3.0.0",
    "@types/jest": "^29.2.6",
    "@types/node": "^18.11.18",
    "eslint": "^8.57.0",
    "fast-csv": "^5.0.1",
    "globals": "^15.2.0",
    "husky": "^9.0.11",
    "jest": "^29.3.1",
    "node-plantuml": "^0.9.0",
    "prettier": "^2.8.3",
    "ton-lite-client": "^3.0.0",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.1",
    "tsdx": "^0.14.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.9.0"
  },
  "peerDependencies": {
    "@ton/core": ">=0.59.0",
    "@ton/crypto": ">=3.2.0",
    "@ton/ton": ">=15.1.0",
    "axios": "^1.4.0"
  },
  "dependencies": {
    "axios": "^1.4.0"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
